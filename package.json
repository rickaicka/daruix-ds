{
  "name": "daruix-ds",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",

    "start": "ng serve ds-playground",
    "start:playground": "ng serve ds-playground",

    "build": "ng build ui",
    "build:ui": "ng build ui",
    "build:ui:dev": "ng build ui --configuration development",
    "build:playground": "ng build ds-playground",

    "watch": "ng build ui --watch --configuration development",

    "test": "ng test",
    "test:ui": "ng test ui",

    "storybook": "ng run ds-playground:storybook",
    "build:storybook": "ng run ds-playground:build-storybook",

    "prepublish:ui": "npm run build:ui",
    "pack:ui": "npm run build:ui && cd dist/ui && npm pack",
    "publish:ui": "npm run build:ui && cd dist/ui && npm publish --access public"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.15",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "storybook": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@compodoc/compodoc": "^1.2.1"
  }
}
