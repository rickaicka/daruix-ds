            "description": "",
            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import {booleanAttribute, Component, computed, input} from '@angular/core';\r\nimport { NgComponentOutlet } from '@angular/common';\r\n\r\nimport { getHubIcon } from './hub-icon.mapper';\r\n\r\n@Component({\r\n  selector: 'app-hub-icon',\r\n  standalone: true,\r\n  imports: [NgComponentOutlet],\r\n  host: {\r\n    '[class.cursor-pointer]': 'action()'\r\n  },\r\n  styleUrls: ['./hub-icon.component.scss'],\r\n  template: `\r\n    <ng-container *ngComponentOutlet=\"iconComponent()\" />\r\n  `\r\n})\r\nexport class HubIconComponent {\r\n  readonly name = input<string | null | undefined>(null);\r\n\r\n  readonly action = input(false, {\r\n    transform: booleanAttribute\r\n  });\r\n\r\n  readonly iconComponent = computed(() =>\r\n    getHubIcon(this.name())\r\n  );\r\n\r\n}\r\n",
            "assetsDirs": [],
            "styleUrlsData": [
                {
                    "data": ":host {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n\r\n  width: var(--hub-icon-size, 24px);\r\n  height: var(--hub-icon-size, 24px);\r\n\r\n  color: inherit;\r\n  line-height: 0;\r\n  flex-shrink: 0;\r\n\r\n  &.cursor-pointer {\r\n    cursor: pointer;\r\n  }\r\n}\r\n\r\n:host ::ng-deep svg {\r\n  width: var(--hub-icon-size, 24px) !important;\r\n  height: var(--hub-icon-size, 24px) !important;\r\n\r\n  min-width: var(--hub-icon-size, 24px);\r\n  min-height: var(--hub-icon-size, 24px);\r\n\r\n  stroke: currentColor;\r\n}\r\n\r\n:host.is-filled {\r\n  color: #f4b400;\r\n}\r\n\r\n:host.is-filled ::ng-deep svg {\r\n  fill: currentColor;\r\n}\r\n",
