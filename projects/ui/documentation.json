            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import { Component, computed, input } from '@angular/core';\r\n\r\nexport type DrxButtonVariant = 'primary' | 'secondary' | 'tertiary';\r\nexport type DrxButtonSize = 'medium' | 'small';\r\nexport type DrxButtonType = 'button' | 'submit' | 'reset';\r\nexport type DrxButtonFont = 'quicksand' | 'gothic' | 'roboto';\r\n\r\n@Component({\r\n  selector: 'drx-button',\r\n  standalone: true,\r\n  templateUrl: './button.component.html',\r\n  styleUrl: './button.component.scss',\r\n})\r\nexport class ButtonComponent {\r\n  variant = input<DrxButtonVariant>('primary');\r\n  size = input<DrxButtonSize>('medium');\r\n  disabled = input(false);\r\n  type = input<DrxButtonType>('button');\r\n  font = input<DrxButtonFont>('quicksand');\r\n\r\n  buttonClasses = computed(() => {\r\n    const classes = [\r\n      'drx-button',\r\n      `drx-button--${this.variant()}`,\r\n      `drx-font-${this.font()}-body`,\r\n      'drx-font-semibold',\r\n    ];\r\n\r\n    if (this.size() === 'small') {\r\n      classes.push('drx-button--small');\r\n    }\r\n\r\n    return classes.join(' ');\r\n  });\r\n}\r\n",
            "styleUrl": "./button.component.scss",
            "assetsDirs": [],
            "styleUrlsData": "",
            "stylesData": "",
            "extends": [],
            "templateData": "<button\r\n  [class]=\"buttonClasses()\"\r\n  [disabled]=\"disabled()\"\r\n  [attr.type]=\"type()\"\r\n>\r\n  <ng-content />\r\n</button>\r\n"
        },
